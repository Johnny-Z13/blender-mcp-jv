*.blend2

# 3D art assets and large binaries (keep repo lean)
*.glb
*.gltf
*.fbx
*.obj
*.mtl
*.ply
*.stl
*.abc
*.usd
*.usdc
*.usda
*.usdz

# Textures and baked images
*.psd
*.exr
*.hdr

# JV working folders — keep the folders, ignore contents
input/*
!input/.gitkeep
output/*
!output/.gitkeep

# OS noise
Thumbs.db

# Editor noise
*.swp
*.swo
.idea/
.vscode/
