# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# macOS
.DS_Store

# Local config secrets
src/blender_mcp/config.py

# Claude Code / IDE local state
.claude/

